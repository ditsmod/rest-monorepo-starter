{
  "private": true,
  "type": "module",
  "name": "monorepo-starter",
  "version": "1.0.0",
  "description": "Starter for monorepositories",
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "test": "tsc -b apps/tsconfig.e2e.json && npm run esm-jest --",
    "esm-jest": "node --experimental-vm-modules --no-warnings=ExperimentalWarning --enable-source-maps node_modules/jest/bin/jest.js",
    "start:dev": "ditsmod start -p apps/backend",
    "start-prod": "node -r dotenv/config apps/backend/dist/main.js dotenv_config_path=apps/backend/.env",
    "build": "tsc -b apps/tsconfig.json",
    "watch": "npm run build -- --watch",
    "lint": "eslint .",
    "setup:agents": "curl -fsSL https://raw.githubusercontent.com/ditsmod/agent-skills/main/AGENTS.md -o AGENTS.md",
    "clean": "rimraf apps/*/dist*"
  },
  "devDependencies": {
    "@ditsmod/cli": "^3.0.0-next.15",
    "@eslint/js": "^10.0.1",
    "@types/eslint__js": "^8.42.3",
    "@types/jest": "^30.0.0",
    "@types/node": "^18.19.130",
    "eslint": "^10.7.0",
    "jest": "^30.4.2",
    "prettier": "^2.8.8",
    "rimraf": "^4.4.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.64.0"
  }
}
